{#
  Quick View Modal Component for Arura Theme
  Features: Product preview without page reload, add to cart, wishlist integration
#}

{# Quick View Modal #}
<div class="quick-view-modal fixed inset-0 z-50 overflow-y-auto"
     x-data="quickViewModal"
     x-show="isOpen"
     x-cloak
     @quick-view.window="openQuickView($event.detail)"
     @keydown.escape.window="closeModal()">
    
    {# Modal Backdrop #}
    <div class="modal-backdrop fixed inset-0 bg-black bg-opacity-50 transition-opacity"
         x-show="isOpen"
         x-transition:enter="ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click="closeModal()">
    </div>
    
    {# Modal Container #}
    <div class="modal-container flex min-h-full items-center justify-center p-4">
        
        {# Modal Content #}
        <div class="modal-content relative bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden"
             x-show="isOpen"
             x-transition:enter="ease-out duration-300"
             x-transition:enter-start="opacity-0 transform scale-95"
             x-transition:enter-end="opacity-100 transform scale-100"
             x-transition:leave="ease-in duration-200"
             x-transition:leave-start="opacity-100 transform scale-100"
             x-transition:leave-end="opacity-0 transform scale-95"
             @click.stop>
            
            {# Close Button #}
            <button class="close-btn absolute top-4 right-4 z-10 w-10 h-10 bg-white hover:bg-gray-100 rounded-full flex items-center justify-center text-gray-600 hover:text-gray-800 transition-all duration-300 shadow-lg"
                    @click="closeModal()">
                <i class="sicon-close text-lg"></i>
            </button>
            
            {# Loading State #}
            <div class="loading-state flex items-center justify-center h-96"
                 x-show="isLoading">
                <div class="text-center">
                    <div class="loading-spinner w-12 h-12 border-4 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
                    <p class="text-gray-600">{{ trans('common.loading') }}...</p>
                </div>
            </div>
            
            {# Product Content #}
            <div class="product-content grid lg:grid-cols-2 gap-0 overflow-y-auto max-h-[90vh]"
                 x-show="!isLoading && product"
                 x-cloak>
                
                {# Product Images #}
                <div class="product-images bg-gray-50 p-6">
                    
                    {# Main Image #}
                    <div class="main-image relative mb-4">
                        <img :src="product?.image?.url || ''" 
                             :alt="product?.name || ''"
                             class="w-full h-96 object-cover rounded-lg">
                             
                        {# Image Badges #}
                        <div class="image-badges absolute top-4 left-4 space-y-2">
                            <span x-show="product?.is_on_sale" 
                                  class="badge bg-red-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                {{ trans('product.sale') }}
                            </span>
                            <span x-show="product?.is_new" 
                                  class="badge bg-green-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                {{ trans('product.new') }}
                            </span>
                        </div>
                    </div>
                    
                    {# Thumbnail Images #}
                    <div class="thumbnail-images flex space-x-2 overflow-x-auto"
                         x-show="product?.images && product.images.length > 1">
                        <template x-for="(image, index) in product?.images || []" :key="index">
                            <img :src="image.url" 
                                 :alt="product.name"
                                 class="w-20 h-20 object-cover rounded-lg cursor-pointer hover:opacity-75 transition-opacity duration-300"
                                 @click="setMainImage(image.url)">
                        </template>
                    </div>
                    
                </div>
                
                {# Product Details #}
                <div class="product-details p-6">
                    
                    {# Product Category #}
                    <div class="product-category mb-2" x-show="product?.category">
                        <span class="text-sm text-gray-500" x-text="product?.category?.name"></span>
                    </div>
                    
                    {# Product Name #}
                    <h2 class="product-name text-2xl lg:text-3xl font-bold text-gray-900 mb-4"
                        x-text="product?.name">
                    </h2>
                    
                    {# Product Rating #}
                    <div class="product-rating flex items-center mb-4" x-show="product?.rating">
                        <div class="stars flex items-center">
                            <template x-for="star in 5" :key="star">
                                <i class="star sicon-star text-lg"
                                   :class="star <= (product?.rating || 0) ? 'text-yellow-400' : 'text-gray-300'"></i>
                            </template>
                        </div>
                        <span class="rating-count text-sm text-gray-500 ml-2"
                              x-text="`(${product?.reviews_count || 0})`">
                        </span>
                    </div>
                    
                    {# Product Price #}
                    <div class="product-price mb-6">
                        <div x-show="product?.is_on_sale" class="price-container flex items-center space-x-3">
                            <span class="sale-price text-2xl font-bold text-primary"
                                  x-text="product?.sale_price">
                            </span>
                            <span class="original-price text-lg text-gray-500 line-through"
                                  x-text="product?.regular_price">
                            </span>
                        </div>
                        <div x-show="!product?.is_on_sale">
                            <span class="regular-price text-2xl font-bold text-gray-900"
                                  x-text="product?.price">
                            </span>
                        </div>
                    </div>
                    
                    {# Product Description #}
                    <div class="product-description mb-6" x-show="product?.description">
                        <h3 class="text-lg font-semibold text-gray-900 mb-2">{{ trans('product.description') }}</h3>
                        <div class="description-text text-gray-600 leading-relaxed max-h-24 overflow-y-auto"
                             x-html="product?.description">
                        </div>
                    </div>
                    
                    {# Product Options (if any) #}
                    <div class="product-options mb-6" x-show="product?.options && product.options.length">
                        <template x-for="option in product?.options || []" :key="option.id">
                            <div class="option-group mb-4">
                                <label class="option-label block text-sm font-medium text-gray-700 mb-2"
                                       x-text="option.name">
                                </label>
                                <select class="option-select w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary focus:border-transparent"
                                        x-model="selectedOptions[option.id]">
                                    <template x-for="value in option.values" :key="value.id">
                                        <option :value="value.id" x-text="value.name"></option>
                                    </template>
                                </select>
                            </div>
                        </template>
                    </div>
                    
                    {# Quantity Selector #}
                    <div class="quantity-selector mb-6">
                        <label class="quantity-label block text-sm font-medium text-gray-700 mb-2">
                            {{ trans('product.quantity') }}
                        </label>
                        <div class="quantity-input flex items-center space-x-3">
                            <button class="quantity-btn decrease w-10 h-10 bg-gray-100 hover:bg-gray-200 rounded-lg flex items-center justify-center text-gray-600 transition-colors duration-300"
                                    @click="decreaseQuantity()"
                                    :disabled="quantity <= 1">
                                <i class="sicon-minus"></i>
                            </button>
                            <input type="number" 
                                   x-model="quantity"
                                   min="1"
                                   class="quantity-field w-20 text-center border border-gray-300 rounded-lg py-2 focus:ring-2 focus:ring-primary focus:border-transparent">
                            <button class="quantity-btn increase w-10 h-10 bg-gray-100 hover:bg-gray-200 rounded-lg flex items-center justify-center text-gray-600 transition-colors duration-300"
                                    @click="increaseQuantity()">
                                <i class="sicon-plus"></i>
                            </button>
                        </div>
                    </div>
                    
                    {# Action Buttons #}
                    <div class="action-buttons space-y-3">
                        
                        {# Add to Cart Button #}
                        <button class="add-to-cart-btn w-full py-3 bg-primary hover:bg-primary-dark text-white rounded-lg font-semibold text-lg transition-all duration-300 transform hover:scale-[1.02] active:scale-[0.98] disabled:opacity-50"
                                @click="addToCart()"
                                :disabled="isAddingToCart || product?.is_out_of_stock"
                                x-show="!product?.is_out_of_stock">
                            <span x-show="!isAddingToCart">{{ trans('product.add_to_cart') }}</span>
                            <span x-show="isAddingToCart" class="flex items-center justify-center">
                                <i class="sicon-loading animate-spin mr-2"></i>
                                {{ trans('product.adding') }}
                            </span>
                        </button>
                        
                        {# Out of Stock Button #}
                        <button class="out-of-stock-btn w-full py-3 bg-gray-300 text-gray-500 rounded-lg font-semibold text-lg cursor-not-allowed"
                                disabled
                                x-show="product?.is_out_of_stock">
                            {{ trans('product.out_of_stock') }}
                        </button>
                        
                        {# Secondary Actions #}
                        <div class="secondary-actions flex space-x-3">
                            
                            {# Wishlist Button #}
                            <button class="wishlist-btn flex-1 py-3 border-2 border-gray-300 hover:border-red-500 text-gray-700 hover:text-red-500 rounded-lg font-medium transition-all duration-300"
                                    :class="{ 'border-red-500 text-red-500 bg-red-50': isInWishlist }"
                                    @click="toggleWishlist()">
                                <i class="sicon-heart mr-2"></i>
                                <span x-text="isInWishlist ? '{{ trans('product.in_wishlist') }}' : '{{ trans('product.add_to_wishlist') }}'"></span>
                            </button>
                            
                            {# View Full Product #}
                            <a :href="product?.url || '#'"
                               class="view-product-btn flex-1 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white rounded-lg font-medium text-center transition-all duration-300"
                               @click="closeModal()">
                                {{ trans('product.view_details') }}
                            </a>
                            
                        </div>
                        
                    </div>
                    
                </div>
                
            </div>
            
        </div>
        
    </div>
    
</div>

{# Alpine.js Quick View Modal Component #}
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('quickViewModal', () => ({
        isOpen: false,
        isLoading: false,
        isAddingToCart: false,
        isInWishlist: false,
        product: null,
        quantity: 1,
        selectedOptions: {},
        
        async openQuickView(data) {
            this.isOpen = true;
            this.isLoading = true;
            this.quantity = 1;
            this.selectedOptions = {};
            
            try {
                // Fetch product data - integrate with Salla API
                const productData = await this.fetchProductData(data.productId);
                this.product = productData;
                this.isInWishlist = productData.is_favorite || false;
                
                // Initialize default options
                if (productData.options) {
                    productData.options.forEach(option => {
                        if (option.values && option.values.length > 0) {
                            this.selectedOptions[option.id] = option.values[0].id;
                        }
                    });
                }
            } catch (error) {
                console.error('Failed to load product:', error);
                // Show error notification
                if (typeof salla !== 'undefined' && salla.notify) {
                    salla.notify.error('{{ trans('product.load_error') }}');
                }
                this.closeModal();
            } finally {
                this.isLoading = false;
            }
        },
        
        closeModal() {
            this.isOpen = false;
            this.product = null;
            this.isLoading = false;
            this.isAddingToCart = false;
            document.body.style.overflow = '';
        },
        
        async fetchProductData(productId) {
            // Mock product data - replace with actual Salla API call
            return new Promise((resolve) => {
                setTimeout(() => {
                    resolve({
                        id: productId,
                        name: 'Sample Product',
                        price: '$99.99',
                        sale_price: '$79.99',
                        regular_price: '$99.99',
                        is_on_sale: true,
                        is_new: false,
                        is_out_of_stock: false,
                        rating: 4.5,
                        reviews_count: 42,
                        description: 'This is a sample product description with all the details you need to know.',
                        image: {
                            url: 'https://via.placeholder.com/600x600'
                        },
                        images: [
                            { url: 'https://via.placeholder.com/600x600' },
                            { url: 'https://via.placeholder.com/600x600' }
                        ],
                        category: {
                            name: 'Electronics'
                        },
                        url: '/products/' + productId,
                        is_favorite: false,
                        options: []
                    });
                }, 1000);
            });
        },
        
        setMainImage(imageUrl) {
            if (this.product && this.product.image) {
                this.product.image.url = imageUrl;
            }
        },
        
        increaseQuantity() {
            this.quantity++;
        },
        
        decreaseQuantity() {
            if (this.quantity > 1) {
                this.quantity--;
            }
        },
        
        async addToCart() {
            this.isAddingToCart = true;
            
            try {
                // Integrate with Salla cart system
                const cartData = {
                    product_id: this.product.id,
                    quantity: this.quantity,
                    options: this.selectedOptions
                };
                
                if (typeof salla !== 'undefined' && salla.cart) {
                    await salla.cart.add(cartData);
                    salla.notify.success('{{ trans('product.added_to_cart') }}');
                } else {
                    // Fallback notification
                    console.log('Added to cart:', cartData);
                }
                
                // Optionally close modal after adding to cart
                // this.closeModal();
                
            } catch (error) {
                console.error('Failed to add to cart:', error);
                if (typeof salla !== 'undefined' && salla.notify) {
                    salla.notify.error('{{ trans('product.add_to_cart_error') }}');
                }
            } finally {
                this.isAddingToCart = false;
            }
        },
        
        toggleWishlist() {
            this.isInWishlist = !this.isInWishlist;
            
            // Integrate with Salla wishlist system
            if (typeof salla !== 'undefined' && salla.wishlist) {
                salla.wishlist.toggle(this.product.id);
            }
            
            const message = this.isInWishlist ? 
                '{{ trans('product.added_to_wishlist') }}' : 
                '{{ trans('product.removed_from_wishlist') }}';
                
            if (typeof salla !== 'undefined' && salla.notify) {
                salla.notify.success(message);
            }
        }
    }));
});
</script>

{# Component Styles #}
<style>
[x-cloak] {
    display: none !important;
}

.quick-view-modal {
    backdrop-filter: blur(4px);
}

.modal-content {
    max-height: 90vh;
    animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: scale(0.95) translateY(20px);
    }
    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.loading-spinner {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    from {
        transform: rotate(0deg);
    }
    to {
        transform: rotate(360deg);
    }
}

.badge {
    backdrop-filter: blur(10px);
}

.add-to-cart-btn {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.add-to-cart-btn:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

.quantity-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.thumbnail-images::-webkit-scrollbar {
    height: 4px;
}

.thumbnail-images::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 2px;
}

.thumbnail-images::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 2px;
}

.thumbnail-images::-webkit-scrollbar-thumb:hover {
    background: #a1a1a1;
}

@media (max-width: 1024px) {
    .modal-content {
        margin: 1rem;
        max-height: calc(100vh - 2rem);
    }
    
    .product-content {
        grid-template-columns: 1fr;
    }
    
    .product-images {
        max-height: 400px;
    }
}

@media (max-width: 640px) {
    .modal-content {
        margin: 0.5rem;
        border-radius: 1rem;
    }
    
    .secondary-actions {
        flex-direction: column;
        space-x: 0;
        gap: 0.75rem;
    }
    
    .secondary-actions > * {
        margin: 0;
    }
}
</style>