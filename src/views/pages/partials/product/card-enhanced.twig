{#
  Enhanced Product Card for Arura Theme
  Features: Quick view, enhanced wishlist, ratings, social sharing
#}

<div class="product-card-enhanced group relative bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 hover:border-primary/20">
    
    {# Product Image Container #}
    <div class="product-image-container relative overflow-hidden">
        
        {# Product Image #}
        <div class="product-image relative aspect-square">
            <img src="{{ product.image.url }}" 
                 alt="{{ product.name }}"
                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                 loading="lazy">
                 
            {# Image Overlay #}
            <div class="image-overlay absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            {# Quick Actions Overlay #}
            <div class="quick-actions absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300">
                
                {# Quick View Button #}
                <button class="quick-view-btn mx-2 w-12 h-12 bg-white hover:bg-primary hover:text-white rounded-full flex items-center justify-center text-gray-700 transition-all duration-300 transform hover:scale-110 shadow-lg"
                        @click="$dispatch('quick-view', { productId: {{ product.id }} })"
                        title="{{ trans('product.quick_view') }}">
                    <i class="sicon-eye text-lg"></i>
                </button>
                
                {# Enhanced Wishlist Button #}
                <button class="wishlist-btn mx-2 w-12 h-12 bg-white hover:bg-red-500 hover:text-white rounded-full flex items-center justify-center text-gray-700 transition-all duration-300 transform hover:scale-110 shadow-lg"
                        :class="{ 'bg-red-500 text-white': isInWishlist }"
                        @click="toggleWishlist({{ product.id }})"
                        x-data="{ isInWishlist: {{ product.is_favorite ? 'true' : 'false' }} }"
                        title="{{ trans('product.add_to_wishlist') }}">
                    <i class="sicon-heart text-lg"></i>
                </button>
                
            </div>
        </div>
        
        {# Product Badges #}
        <div class="product-badges absolute top-3 left-3 space-y-2">
            {% if product.is_on_sale %}
                <span class="badge sale-badge bg-red-500 text-white px-3 py-1 rounded-full text-xs font-semibold">
                    {% if product.sale_end %}
                        {{ trans('product.sale') }}
                    {% else %}
                        -{{ product.discount_percent }}%
                    {% endif %}
                </span>
            {% endif %}
            
            {% if product.is_new %}
                <span class="badge new-badge bg-green-500 text-white px-3 py-1 rounded-full text-xs font-semibold">
                    {{ trans('product.new') }}
                </span>
            {% endif %}
            
            {% if product.is_out_of_stock %}
                <span class="badge out-of-stock-badge bg-gray-500 text-white px-3 py-1 rounded-full text-xs font-semibold">
                    {{ trans('product.out_of_stock') }}
                </span>
            {% endif %}
        </div>
        
        {# Social Share Button #}
        <div class="social-share absolute top-3 right-3">
            <button class="share-btn w-8 h-8 bg-white/80 hover:bg-white rounded-full flex items-center justify-center text-gray-600 hover:text-primary transition-all duration-300 opacity-0 group-hover:opacity-100"
                    @click="shareProduct({{ product.id }})"
                    title="{{ trans('product.share') }}">
                <i class="sicon-share text-sm"></i>
            </button>
        </div>
        
    </div>
    
    {# Product Content #}
    <div class="product-content p-4">
        
        {# Product Category #}
        {% if product.category %}
            <div class="product-category mb-2">
                <span class="category-link text-xs text-gray-500 hover:text-primary transition-colors duration-300">
                    {{ product.category.name }}
                </span>
            </div>
        {% endif %}
        
        {# Product Name #}
        <h3 class="product-name mb-3">
            <a href="{{ product.url }}" 
               class="text-gray-900 hover:text-primary font-semibold text-sm leading-tight line-clamp-2 transition-colors duration-300">
                {{ product.name }}
            </a>
        </h3>
        
        {# Product Rating #}
        {% if product.rating %}
            <div class="product-rating flex items-center mb-3">
                <div class="stars flex items-center">
                    {% for i in 1..5 %}
                        <i class="star sicon-star text-sm {{ i <= product.rating ? 'text-yellow-400' : 'text-gray-300' }}"></i>
                    {% endfor %}
                </div>
                <span class="rating-count text-xs text-gray-500 mx-2">({{ product.reviews_count }})</span>
            </div>
        {% endif %}
        
        {# Product Price #}
        <div class="product-price mb-4">
            {% if product.is_on_sale %}
                <div class="price-container flex items-center space-x-2">
                    <span class="sale-price text-lg font-bold text-primary">
                        {{ product.sale_price }}
                    </span>
                    <span class="original-price text-sm text-gray-500 line-through">
                        {{ product.regular_price }}
                    </span>
                </div>
            {% else %}
                <span class="regular-price text-lg font-bold text-gray-900">
                    {{ product.price }}
                </span>
            {% endif %}
        </div>
        
        {# Add to Cart Button #}
        <div class="product-actions">
            {% if product.is_out_of_stock %}
                <button class="add-to-cart-btn w-full py-3 bg-gray-300 text-gray-500 rounded-lg font-medium cursor-not-allowed"
                        disabled>
                    {{ trans('product.out_of_stock') }}
                </button>
            {% else %}
                <button class="add-to-cart-btn w-full py-3 bg-primary hover:bg-primary-dark text-white rounded-lg font-medium transition-all duration-300 transform hover:scale-[1.02] active:scale-[0.98]"
                        @click="addToCart({{ product.id }})"
                        :disabled="isAdding"
                        x-data="{ isAdding: false }">
                    <span x-show="!isAdding">{{ trans('product.add_to_cart') }}</span>
                    <span x-show="isAdding" class="flex items-center justify-center">
                        <i class="sicon-loading animate-spin mr-2"></i>
                        {{ trans('product.adding') }}
                    </span>
                </button>
            {% endif %}
        </div>
        
    </div>
    
</div>

{# Component Styles #}
<style>
.product-card-enhanced {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.product-card-enhanced:hover {
    transform: translateY(-8px);
}

.badge {
    backdrop-filter: blur(10px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.quick-actions button {
    backdrop-filter: blur(10px);
}

.add-to-cart-btn {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.add-to-cart-btn:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

.add-to-cart-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none !important;
}

.star {
    transition: color 0.2s ease;
}

.star:hover {
    transform: scale(1.1);
}

.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

@media (max-width: 640px) {
    .product-content {
        padding: 12px;
    }
    
    .product-name {
        font-size: 0.875rem;
    }
    
    .add-to-cart-btn {
        padding: 10px;
        font-size: 0.875rem;
    }
}
</style>

{# JavaScript for enhanced functionality #}
<script>
// Global product card functions
window.productCardActions = {
    toggleWishlist: function(productId) {
        // Integrate with Salla wishlist system
        if (typeof salla !== 'undefined' && salla.wishlist) {
            salla.wishlist.toggle(productId);
        }
    },
    
    addToCart: function(productId) {
        // Integrate with Salla cart system
        if (typeof salla !== 'undefined' && salla.cart) {
            salla.cart.add({
                product_id: productId,
                quantity: 1
            });
        }
    },
    
    shareProduct: function(productId) {
        // Social sharing functionality
        if (navigator.share) {
            navigator.share({
                title: document.title,
                url: window.location.href
            });
        } else {
            // Fallback to copy URL
            navigator.clipboard.writeText(window.location.href);
            // Show notification
            salla.notify.success('{{ trans("product.link_copied") }}');
        }
    }
};

// Bind functions to Alpine.js context
document.addEventListener('alpine:init', () => {
    Alpine.data('productCard', () => ({
        isAdding: false,
        isInWishlist: false,
        
        toggleWishlist(productId) {
            this.isInWishlist = !this.isInWishlist;
            window.productCardActions.toggleWishlist(productId);
        },
        
        async addToCart(productId) {
            this.isAdding = true;
            try {
                await window.productCardActions.addToCart(productId);
            } finally {
                this.isAdding = false;
            }
        },
        
        shareProduct(productId) {
            window.productCardActions.shareProduct(productId);
        }
    }));
});
</script>